---
import { translations } from '../data/translations.js';
const en = translations.en.video;
const es = translations.es.video;
---

<section class="section reveal">
  <div class="container">
    <h2 class="section-title reveal" data-en={en.title} data-es={es.title}>{en.title}</h2>
    <div class="card video-card reveal">
      <div class="video-wrapper">
        <iframe
          src="https://www.youtube.com/embed/RiFfMuun2i8"
          title="Hantavirus informative video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
      <p class="video-caption" data-en={en.caption} data-es={es.caption}>{en.caption}</p>
    </div>
  </div>
</section>

<style>
  .video-card { padding: 1.5rem; }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
  }
  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .video-caption {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
  }
</style>
