---
import { translations } from '../data/translations.js';
const en = translations.en.hero;
const es = translations.es.hero;
const authors = [
  "Jesus Manuel Lopez Villalpando",
  "Jovani Alexander Florez de Loera",
  "Max Gonzales Velasquez",
  "Geovanny Guadalupe Alvarado Renovato",
  "Esteban Loera Loera"
];
---

<section class="hero" id="hero">
  <canvas id="heroCanvas" aria-hidden="true"></canvas>
  <div class="hero-content">
    <span class="hero-kicker">MV Hondius 2026</span>
    <h1 class="hero-title" data-en={en.title} data-es={es.title}>{en.title}</h1>
    <p class="hero-subtitle" data-en={en.subtitle} data-es={es.subtitle}>{en.subtitle}</p>
    <div class="hero-actions" aria-label="Page shortcuts">
      <a href="#timeline" data-en="View timeline" data-es="Ver linea de tiempo">View timeline</a>
      <a href="#data" data-en="Review key data" data-es="Revisar datos clave">Review key data</a>
    </div>
    <div class="authors">
      {authors.map((a) => <span class="author">{a}</span>)}
    </div>
    <p class="institution" data-en={en.institution} data-es={es.institution}>{en.institution}</p>
    <p class="date" data-en={en.date} data-es={es.date}>{en.date}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-height: calc(100svh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: clip;
    padding: 5rem clamp(1rem, 4vw, 1.5rem) 4rem;
    isolation: isolate;
  }
  #heroCanvas {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    z-index: 0;
    background: #020617;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 38%, rgba(20, 184, 166, 0.18), transparent 32rem),
      linear-gradient(180deg, rgba(2, 6, 23, 0.16), rgba(2, 6, 23, 0.84));
  }
  .hero-content {
    position: relative;
    z-index: 1;
    width: min(880px, 100%);
    max-width: 100%;
    text-align: center;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-kicker {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(20, 184, 166, 0.32);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    margin-bottom: 1.35rem;
    color: #5eead4;
    background: rgba(13, 148, 136, 0.1);
    backdrop-filter: blur(12px);
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .hero-title {
    font-size: clamp(2rem, 6vw, 4.2rem);
    color: #f8fafc;
    margin-bottom: 1.25rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: 0;
    text-shadow: 0 4px 30px rgba(0,0,0,0.5);
    overflow-wrap: anywhere;
  }
  .hero-subtitle {
    max-width: 720px;
    margin: 0 auto 2rem;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: #cbd5e1;
    line-height: 1.6;
    text-shadow: 0 2px 10px rgba(0,0,0,0.4);
  }
  .hero-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .hero-actions a {
    max-width: 100%;
    border-radius: 12px;
    padding: 0.85rem 1.5rem;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    background: #0d9488;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 10px 30px rgba(13, 148, 136, 0.3), inset 0 1px 0 rgba(255,255,255,0.2);
    transition: transform var(--transition), background var(--transition), box-shadow var(--transition);
  }
  .hero-actions a:hover {
    text-decoration: none;
    background: #14b8a6;
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(20, 184, 166, 0.4), inset 0 1px 0 rgba(255,255,255,0.3);
  }
  .hero-actions a:nth-child(2) {
    background: rgba(30, 41, 59, 0.64);
    backdrop-filter: blur(10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  .authors {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .author {
    max-width: 100%;
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    background: rgba(15, 23, 42, 0.4);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    color: #cbd5e1;
    font-size: 0.85rem;
  }
  .institution, .date {
    color: #94a3b8;
    font-size: 0.95rem;
    font-weight: 500;
  }
  @media (max-width: 640px) {
    .hero {
      min-height: auto;
      padding-top: 4.5rem;
      padding-bottom: 3rem;
    }
    .hero-actions {
      gap: 0.75rem;
      margin-bottom: 2rem;
    }
    .hero-actions a { width: 100%; }
    .authors { gap: 0.5rem; }
    .author { font-size: 0.8rem; }
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(58, 1, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setClearColor('#020617', 1);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  scene.fog = new THREE.FogExp2('#020617', 0.035);

  const root = new THREE.Group();
  scene.add(root);

  const particleCount = window.innerWidth < 700 ? 900 : 1500;
  const particleGeo = new THREE.BufferGeometry();
  const positions = new Float32Array(particleCount * 3);
  const sizes = new Float32Array(particleCount);

  for (let i = 0; i < particleCount; i++) {
    const radius = 7 + Math.random() * 16;
    const theta = Math.random() * Math.PI * 2;
    const y = (Math.random() - 0.5) * 12;
    positions[i * 3] = Math.cos(theta) * radius;
    positions[i * 3 + 1] = y;
    positions[i * 3 + 2] = Math.sin(theta) * radius;
    sizes[i] = 0.45 + Math.random() * 1.4;
  }

  particleGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  particleGeo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

  const particleMat = new THREE.ShaderMaterial({
    transparent: true,
    depthWrite: false,
    blending: THREE.AdditiveBlending,
    vertexShader: `
      attribute float size;
      varying float vDepth;
      void main() {
        vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
        vDepth = clamp((-mvPosition.z - 2.0) / 18.0, 0.0, 1.0);
        gl_PointSize = size * (260.0 / -mvPosition.z);
        gl_Position = projectionMatrix * mvPosition;
      }
    `,
    fragmentShader: `
      varying float vDepth;
      void main() {
        float d = distance(gl_PointCoord, vec2(0.5));
        if (d > 0.5) discard;
        float glow = smoothstep(0.5, 0.06, d);
        vec3 color = mix(vec3(0.08, 0.45, 0.42), vec3(0.36, 0.92, 0.83), vDepth);
        gl_FragColor = vec4(color, glow * 0.72);
      }
    `
  });

  const particles = new THREE.Points(particleGeo, particleMat);
  root.add(particles);

  const core = new THREE.Group();
  root.add(core);

  const outer = new THREE.Mesh(
    new THREE.IcosahedronGeometry(2.25, 3),
    new THREE.MeshBasicMaterial({
      color: '#14b8a6',
      wireframe: true,
      transparent: true,
      opacity: 0.22,
      blending: THREE.AdditiveBlending
    })
  );
  core.add(outer);

  const inner = new THREE.Mesh(
    new THREE.IcosahedronGeometry(1.08, 2),
    new THREE.MeshBasicMaterial({
      color: '#2dd4bf',
      transparent: true,
      opacity: 0.55,
      blending: THREE.AdditiveBlending
    })
  );
  core.add(inner);

  const spikeMat = new THREE.LineBasicMaterial({ color: '#5eead4', transparent: true, opacity: 0.42 });
  const spikePositions: number[] = [];
  for (let i = 0; i < 54; i++) {
    const v = new THREE.Vector3().randomDirection();
    spikePositions.push(v.x * 2.15, v.y * 2.15, v.z * 2.15);
    spikePositions.push(v.x * 3.0, v.y * 3.0, v.z * 3.0);
  }
  const spikeGeo = new THREE.BufferGeometry();
  spikeGeo.setAttribute('position', new THREE.Float32BufferAttribute(spikePositions, 3));
  core.add(new THREE.LineSegments(spikeGeo, spikeMat));

  const pointer = { x: 0, y: 0 };
  window.addEventListener('pointermove', (event) => {
    pointer.x = (event.clientX / window.innerWidth - 0.5) * 0.6;
    pointer.y = (event.clientY / window.innerHeight - 0.5) * 0.4;
  }, { passive: true });

  const resize = () => {
    const width = canvas.clientWidth || window.innerWidth;
    const height = canvas.clientHeight || window.innerHeight;
    camera.aspect = width / height;
    camera.position.z = width < 700 ? 14 : 11;
    camera.updateProjectionMatrix();
    renderer.setSize(width, height, false);
  };
  resize();
  window.addEventListener('resize', resize);

  const clock = new THREE.Clock();
  const animate = () => {
    const t = clock.getElapsedTime();
    requestAnimationFrame(animate);

    root.rotation.y += (pointer.x - root.rotation.y) * 0.025;
    root.rotation.x += (-pointer.y - root.rotation.x) * 0.025;
    particles.rotation.y = t * 0.045;
    particles.rotation.x = Math.sin(t * 0.2) * 0.08;
    core.rotation.y = t * 0.28;
    core.rotation.x = Math.sin(t * 0.6) * 0.14;

    const pulse = 1 + Math.sin(t * 2.2) * 0.045;
    outer.scale.setScalar(pulse);
    inner.scale.setScalar(0.92 + Math.sin(t * 2.2 + 0.8) * 0.035);

    renderer.render(scene, camera);
  };
  animate();

  window.addEventListener('langchange', (e: any) => {
    const lang = e.detail;
    document.querySelectorAll('[data-en][data-es]').forEach((el) => {
      const text = lang === 'es' ? el.getAttribute('data-es') : el.getAttribute('data-en');
      if (text) el.textContent = text;
    });
  });

  const initLang = localStorage.getItem('lang') || 'en';
  if (initLang === 'es') {
    document.querySelectorAll('[data-en][data-es]').forEach((el) => {
      const text = el.getAttribute('data-es');
      if (text) el.textContent = text;
    });
  }
</script>
