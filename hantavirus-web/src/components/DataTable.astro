---
import { translations } from '../data/translations.js';
const en = translations.en.data;
const es = translations.es.data;
---

<section class="section reveal" id="data">
  <div class="container">
    <h2 class="section-title reveal" data-en={en.title} data-es={es.title}>{en.title}</h2>
    <div class="data-highlights" aria-label="Outbreak summary">
      {en.highlights.map((item, i) => (
        <article class="highlight-card card reveal" style={`transition-delay: ${Math.min(i * 0.08, 0.24)}s`}>
          <strong data-en={item.value} data-es={es.highlights[i].value}>{item.value}</strong>
          <span data-en={item.label} data-es={es.highlights[i].label}>{item.label}</span>
        </article>
      ))}
    </div>
    <div class="table-wrapper card reveal" role="region" aria-labelledby="data-table-title">
      <table id="dataTable">
        <caption id="data-table-title" data-en={en.title} data-es={es.title}>{en.title}</caption>
        <thead>
          <tr>
            <th data-en={en.headers[0]} data-es={es.headers[0]}>{en.headers[0]}</th>
            <th data-en={en.headers[1]} data-es={es.headers[1]}>{en.headers[1]}</th>
          </tr>
        </thead>
        <tbody>
          {en.rows.map((row, i) => (
            <tr>
              <td data-en={row[0]} data-es={es.rows[i][0]}>{row[0]}</td>
              <td data-en={row[1]} data-es={es.rows[i][1]}>{row[1]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .data-highlights {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .highlight-card {
    padding: 1.2rem;
    min-height: 118px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-color: color-mix(in srgb, var(--color-accent) 24%, var(--color-border));
  }
  .highlight-card strong {
    display: block;
    color: var(--color-accent);
    font-size: clamp(1.8rem, 4vw, 2.55rem);
    line-height: 1;
  }
  .highlight-card span {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.35;
  }
  .table-wrapper { overflow-x: auto; padding: 0; }
  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 560px;
  }
  caption {
    text-align: left;
    padding: 1rem 1rem 0;
    font-weight: 700;
    color: var(--color-text);
  }
  th, td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  th {
    background: var(--color-surface-alt);
    font-weight: 700;
    color: var(--color-primary);
    position: sticky;
    top: 0;
  }
  [data-theme="dark"] th { color: var(--color-accent); }
  tr:hover td { background: var(--color-surface-alt); }
  @media (max-width: 820px) {
    .data-highlights { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 480px) {
    .data-highlights { grid-template-columns: 1fr; }
    .highlight-card { min-height: auto; gap: 0.75rem; }
  }
</style>
