---
const formUrl = "https://docs.google.com/forms/d/e/1FAIpQLSfcyGrY71QFoew6Ud9R_CRrRif1Mhh0Aeo5LBlKYCcm4zO6sA/viewform";
const embedUrl = `${formUrl}?embedded=true`;
---

<section class="section reveal" id="contact">
  <div class="container">
    <div class="form-layout">
      <div>
        <h2 class="section-title reveal" data-en="Survey form" data-es="Formulario de encuesta">Survey form</h2>
        <p class="form-copy reveal" data-en="Please answer this Google Form to help complete the academic project." data-es="Contesta este formulario de Google para ayudar a completar el proyecto académico.">
          Please answer this Google Form to help complete the academic project.
        </p>
        <a class="form-link reveal" href={formUrl} target="_blank" rel="noopener noreferrer" data-en="Open form in a new tab" data-es="Abrir formulario en otra pestaña">
          Open form in a new tab
        </a>
      </div>
      <div class="form-frame card reveal">
        <iframe
          src={embedUrl}
          title="Hantavirus survey Google Form"
          loading="lazy"
        >
          Loading...
        </iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .form-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(320px, 1.25fr);
    gap: 2rem;
    align-items: start;
  }
  .form-copy {
    color: var(--color-text-muted);
    max-width: 32rem;
    margin-bottom: 1rem;
  }
  .form-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 0.85rem 1.1rem;
    background: var(--color-accent);
    color: #fff;
    font-weight: 800;
  }
  .form-link:hover {
    color: #fff;
    text-decoration: none;
    background: var(--color-accent-hover);
  }
  .form-frame {
    padding: 0;
    overflow: hidden;
    min-height: 680px;
  }
  .form-frame iframe {
    display: block;
    width: 100%;
    height: 680px;
    border: 0;
    background: #fff;
  }
  @media (max-width: 780px) {
    .form-layout { grid-template-columns: 1fr; }
    .form-link { width: 100%; }
    .form-frame,
    .form-frame iframe {
      min-height: 720px;
      height: 720px;
    }
  }
</style>
