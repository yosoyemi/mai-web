<section class="section reveal" id="contact">
  <div class="container">
    <div class="form-layout">
      <div>
        <h2 class="section-title reveal" data-en="Questions or comments" data-es="Preguntas o comentarios">Questions or comments</h2>
        <p class="form-copy reveal" data-en="Use this form to leave feedback, questions, or notes for the academic project." data-es="Usa este formulario para dejar comentarios, preguntas o notas para el proyecto académico.">
          Use this form to leave feedback, questions, or notes for the academic project.
        </p>
      </div>
      <form class="contact-form card reveal" name="hantavirus-feedback" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="hantavirus-feedback" />
        <label>
          <span data-en="Name" data-es="Nombre">Name</span>
          <input name="name" type="text" required data-placeholder-en="Your name" data-placeholder-es="Tu nombre" placeholder="Your name" />
        </label>
        <label>
          <span data-en="Email" data-es="Correo">Email</span>
          <input name="email" type="email" required data-placeholder-en="you@example.com" data-placeholder-es="tu@ejemplo.com" placeholder="you@example.com" />
        </label>
        <label>
          <span data-en="Topic" data-es="Tema">Topic</span>
          <select name="topic" required>
            <option value="question" data-en="Question" data-es="Pregunta">Question</option>
            <option value="correction" data-en="Correction" data-es="Corrección">Correction</option>
            <option value="source" data-en="Source suggestion" data-es="Sugerencia de fuente">Source suggestion</option>
          </select>
        </label>
        <label>
          <span data-en="Message" data-es="Mensaje">Message</span>
          <textarea name="message" rows="5" required data-placeholder-en="Write your message..." data-placeholder-es="Escribe tu mensaje..." placeholder="Write your message..."></textarea>
        </label>
        <button type="submit" data-en="Send message" data-es="Enviar mensaje">Send message</button>
      </form>
    </div>
  </div>
</section>

<style>
  .form-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(300px, 1.2fr);
    gap: 2rem;
    align-items: start;
  }
  .form-copy {
    color: var(--color-text-muted);
    max-width: 32rem;
  }
  .contact-form {
    display: grid;
    gap: 1rem;
  }
  .contact-form label {
    display: grid;
    gap: 0.4rem;
    color: var(--color-text);
    font-weight: 700;
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.85rem 0.95rem;
    background: var(--color-surface-alt);
    color: var(--color-text);
    font: inherit;
  }
  .contact-form textarea { resize: vertical; min-height: 130px; }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .contact-form button {
    justify-self: start;
    border: 0;
    border-radius: 8px;
    padding: 0.85rem 1.2rem;
    background: var(--color-accent);
    color: #fff;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
    transition: transform var(--transition), background var(--transition);
  }
  .contact-form button:hover {
    transform: translateY(-2px);
    background: var(--color-accent-hover);
  }
  @media (max-width: 780px) {
    .form-layout { grid-template-columns: 1fr; }
    .contact-form button { width: 100%; }
  }
</style>
