---
import { translations } from '../data/translations.js';
const en = translations.en.hero;
const es = translations.es.hero;
const authors = [
  "Jesus Manuel Lopez Villalpando",
  "Jovani Alexander Florez de Loera",
  "Max Gonzales Velasquez",
  "Geovanny Guadalupe Alvarado Renovato",
  "Esteban Loera Loera"
];
---

<section class="hero" id="hero">
  <canvas id="heroCanvas"></canvas>
  <div class="hero-content">
    <span class="hero-kicker">MV Hondius 2026</span>
    <h1 class="hero-title" data-en={en.title} data-es={es.title}>{en.title}</h1>
    <p class="hero-subtitle" data-en={en.subtitle} data-es={es.subtitle}>{en.subtitle}</p>
    <div class="hero-actions" aria-label="Page shortcuts">
      <a href="#timeline" data-en="View timeline" data-es="Ver linea de tiempo">View timeline</a>
      <a href="#data" data-en="Review key data" data-es="Revisar datos clave">Review key data</a>
    </div>
    <div class="authors">
      {authors.map((a) => <span class="author">{a}</span>)}
    </div>
    <p class="institution" data-en={en.institution} data-es={es.institution}>{en.institution}</p>
    <p class="date" data-en={en.date} data-es={es.date}>{en.date}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 5rem 1.5rem 4rem;
  }
  #heroCanvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    background: #020617; /* Slate 950 base for particles */
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, transparent 40%, rgba(2, 6, 23, 0.8) 100%);
    z-index: 0;
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    width: min(880px, 100%);
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-kicker {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(20, 184, 166, 0.3);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    margin-bottom: 1.5rem;
    color: #5eead4;
    background: rgba(13, 148, 136, 0.1);
    backdrop-filter: blur(12px);
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: #f8fafc;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 30px rgba(0,0,0,0.5);
  }
  .hero-subtitle {
    max-width: 720px;
    margin: 0 auto 2rem;
    font-size: clamp(1.1rem, 2.5vw, 1.25rem);
    color: #cbd5e1;
    line-height: 1.6;
    text-shadow: 0 2px 10px rgba(0,0,0,0.4);
  }
  .hero-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .hero-actions a {
    border-radius: 12px;
    padding: 0.85rem 1.75rem;
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    background: #0d9488;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 10px 30px rgba(13, 148, 136, 0.3), inset 0 1px 0 rgba(255,255,255,0.2);
    transition: all 0.3s ease;
  }
  .hero-actions a:hover {
    text-decoration: none;
    background: #14b8a6;
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(20, 184, 166, 0.4), inset 0 1px 0 rgba(255,255,255,0.3);
  }
  .hero-actions a:nth-child(2) {
    background: rgba(30, 41, 59, 0.6);
    backdrop-filter: blur(10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  .hero-actions a:nth-child(2):hover {
    background: rgba(51, 65, 85, 0.8);
  }
  .authors {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .author {
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    background: rgba(15, 23, 42, 0.4);
    border: 1px solid rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    color: #94a3b8;
    font-size: 0.85rem;
    transition: color 0.3s ease;
  }
  .author:hover { color: #f8fafc; }
  .institution, .date {
    color: #64748b;
    font-size: 0.95rem;
    font-weight: 500;
  }
  @media (max-width: 640px) {
    .hero {
      align-items: flex-start;
      min-height: auto;
      padding-top: 6rem;
    }
    .hero-actions a { width: 100%; }
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setSize(canvas.clientWidth, canvas.clientHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  // Add a nice fog
  scene.fog = new THREE.FogExp2('#020617', 0.04);

  const group = new THREE.Group();
  scene.add(group);

  // Particles (Virus-like or data points)
  const count = 3000;
  const geo = new THREE.BufferGeometry();
  const pos = new Float32Array(count * 3);
  const sizes = new Float32Array(count);
  
  for (let i = 0; i < count * 3; i+=3) {
    const radius = 10 + Math.random() * 20;
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos((Math.random() * 2) - 1);
    
    pos[i] = radius * Math.sin(phi) * Math.cos(theta); // x
    pos[i+1] = radius * Math.sin(phi) * Math.sin(theta); // y
    pos[i+2] = radius * Math.cos(phi); // z
    
    sizes[i/3] = Math.random() * 1.5;
  }
  
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  geo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
  
  // Custom shader material for glow
  const vertexShader = `
    attribute float size;
    varying vec3 vColor;
    void main() {
      vColor = vec3(0.08, 0.72, 0.65); // Accent color
      vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
      gl_PointSize = size * (300.0 / -mvPosition.z);
      gl_Position = projectionMatrix * mvPosition;
    }
  `;
  const fragmentShader = `
    varying vec3 vColor;
    void main() {
      float r = distance(gl_PointCoord, vec2(0.5, 0.5));
      if (r > 0.5) discard;
      float alpha = smoothstep(0.5, 0.1, r);
      gl_FragColor = vec4(vColor, alpha * 0.8);
    }
  `;

  const mat = new THREE.ShaderMaterial({
    vertexShader,
    fragmentShader,
    transparent: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false
  });

  const points = new THREE.Points(geo, mat);
  group.add(points);

  // Central nucleus (Virus core)
  const sphereGeo = new THREE.IcosahedronGeometry(2.5, 3);
  const sphereMat = new THREE.MeshBasicMaterial({ 
    color: '#0d9488', 
    wireframe: true, 
    transparent: true, 
    opacity: 0.15,
    blending: THREE.AdditiveBlending
  });
  const sphere = new THREE.Mesh(sphereGeo, sphereMat);
  group.add(sphere);
  
  // Inner core
  const innerGeo = new THREE.IcosahedronGeometry(1.2, 2);
  const innerMat = new THREE.MeshBasicMaterial({ 
    color: '#14b8a6', 
    wireframe: false, 
    transparent: true, 
    opacity: 0.8,
  });
  const innerSphere = new THREE.Mesh(innerGeo, innerMat);
  group.add(innerSphere);

  camera.position.z = 12;

  // Mouse interaction
  let mouseX = 0;
  let mouseY = 0;
  let targetX = 0;
  let targetY = 0;

  window.addEventListener('mousemove', (e) => {
    mouseX = (e.clientX - window.innerWidth / 2) * 0.001;
    mouseY = (e.clientY - window.innerHeight / 2) * 0.001;
  });

  const clock = new THREE.Clock();

  function animate() {
    requestAnimationFrame(animate);
    const elapsedTime = clock.getElapsedTime();

    targetX = mouseX * 2;
    targetY = mouseY * 2;

    group.rotation.y += 0.05 * (targetX - group.rotation.y);
    group.rotation.x += 0.05 * (targetY - group.rotation.x);

    points.rotation.y += 0.0005;
    points.rotation.x += 0.0002;
    
    sphere.rotation.y += 0.002;
    sphere.rotation.x += 0.001;
    
    // Pulse effect
    const scale = 1 + Math.sin(elapsedTime * 2) * 0.05;
    sphere.scale.set(scale, scale, scale);
    innerSphere.scale.set(scale, scale, scale);

    // Dynamic wave in particles
    const positions = geo.attributes.position.array as Float32Array;
    for(let i = 0; i < count; i++) {
      const ix = i * 3;
      const iy = i * 3 + 1;
      const iz = i * 3 + 2;
      // Slight breathing
      positions[ix] += Math.sin(elapsedTime + positions[iy]) * 0.01;
      positions[iy] += Math.cos(elapsedTime + positions[ix]) * 0.01;
    }
    geo.attributes.position.needsUpdate = true;

    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize', () => {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });

  window.addEventListener('langchange', (e: any) => {
    const lang = e.detail;
    document.querySelectorAll('[data-en][data-es]').forEach((el) => {
      const text = lang === 'es' ? el.getAttribute('data-es') : el.getAttribute('data-en');
      if (text) el.textContent = text;
    });
  });

  const initLang = localStorage.getItem('lang') || 'en';
  if (initLang === 'es') {
    document.querySelectorAll('[data-en][data-es]').forEach((el) => {
      const text = el.getAttribute('data-es');
      if (text) el.textContent = text;
    });
  }
</script>
