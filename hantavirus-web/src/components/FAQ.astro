---
import { translations } from '../data/translations.js';
const en = translations.en.faq;
const es = translations.es.faq;
---

<section class="section reveal" id="faq">
  <div class="container">
    <h2 class="section-title reveal" data-en={en.title} data-es={es.title}>{en.title}</h2>
    <div class="faq-list">
      {en.items.map((item, i) => (
        <details class="faq-item card reveal" style={`transition-delay: ${Math.min(i * 0.1, 0.5)}s`}>
          <summary data-en={item.q} data-es={es.items[i].q}>{item.q}</summary>
          <p data-en={item.a} data-es={es.items[i].a}>{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list { display: grid; gap: 1rem; }
  .faq-item {
    cursor: pointer;
    padding: 1.1rem 1.25rem;
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
    transform: rotate(-45deg);
    transition: transform var(--transition);
    flex: 0 0 auto;
  }
  .faq-item[open] summary::before { transform: rotate(45deg); }
  [data-theme="dark"] .faq-item summary { color: var(--color-accent); }
  .faq-item p {
    padding: 1rem 0 0.2rem 1.3rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
</style>
